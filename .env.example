# .env.example — copy to .env and fill in your real values. NEVER commit .env.

# OpenRouter (AI gateway for Gemini + GPT-4o)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Supabase — find these in: Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Frontend — URL of the running Flask backend
NEXT_PUBLIC_API_URL=http://localhost:5000

# MCP server — set a strong random secret before running backend/mcp_server.py
MCP_SECRET_KEY=your-mcp-secret-key-here
